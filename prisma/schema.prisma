// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]
  repositories  Repository[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Repository {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String   @map("full_name")
  owner     String
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  source    String   @default("manual")
  tasks     Task[]

  @@unique([userId, fullName])
  @@map("repositories")
}

model Task {
  id             Int        @id @default(autoincrement())
  githubId       BigInt     @map("github_id")
  repoId         Int        @map("repo_id")
  repository     Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  title          String
  state          String
  type           String
  url            String
  number         Int
  assigneeAvatar String?    @map("assignee_avatar")
  assigneeLogin  String?    @map("assignee_login")
  body           String?
  boardStatus    String?    @map("board_status")
  labels         String?    // JSON array stored as text
  milestone      String?
  createdAt      DateTime   @map("created_at")
  updatedAt      DateTime   @map("updated_at")

  @@unique([githubId, repoId])
  @@index([state])
  @@index([type])
  @@index([boardStatus])
  @@index([updatedAt])
  @@index([repoId])
  @@map("tasks")
}
