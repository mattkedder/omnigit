# OmniGit Configuration
# Copy this file to .env and fill in your values

# Database URL (default: SQLite)
# DATABASE_URL=sqlite:///task_dashboard.db
DATABASE_URL="file:./instance/next_dashboard.db"
GITHUB_ID="your_actual_github_client_id"
GITHUB_SECRET="your_actual_github_client_secret"
NEXTAUTH_SECRET="a_random_secure_string_here"
NEXTAUTH_URL="http://localhost:7492"
