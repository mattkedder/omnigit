# OmniGit Configuration
# Copy this file to .env and fill in your values

# GitHub personal access token (with 'repo' scope)
# GITHUB_TOKEN=ghp_...

# Secret key for session/CSRF (generate a random string)
SECRET_KEY=change-me-to-a-random-string

# Webhook sync token (for external sync API)
SYNC_TOKEN=change-me-in-production

# Webhook secret (for GitHub webhook signature verification)
# WEBHOOK_SECRET=your-webhook-secret

# Database URL (default: SQLite)
# DATABASE_URL=sqlite:///task_dashboard.db
